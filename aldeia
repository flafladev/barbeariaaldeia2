<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Barbearia Aldeia - Estilo e Tradição</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <header class="header">
        <nav class="navbar">
            <div class="logo">
                <img src="fotoaldeia1.jpeg" alt="Barbearia Aldeia">
                <h1>Barbearia Aldeia</h1>
            </div>
            <ul class="nav-links">
                <li><a href="index.html" class="active">Início</a></li>
                <li><a href="#servicos">Serviços</a></li>
                <li><a href="agendamento.html">Agendar</a></li>
                <li><a href="historico.html">Histórico</a></li>
                <li><a href="#contato">Contato</a></li>
            </ul>
            <div class="burger">
                <div class="line1"></div>
                <div class="line2"></div>
                <div class="line3"></div>
            </div>
        </nav>
    </header>

    <main>
        <section class="hero">
            <div class="hero-image-container">
                <img src="fotoaldeia2.jpeg" alt="Barbeiro Aldeia" class="hero-img">
                <div class="hero-overlay"></div>
            </div>
            <div class="hero-content">
                <h2 class="hero-title">Bem-vindo à Barbearia Aldeia</h2>
                <p class="hero-subtitle">Tradição e estilo em cada corte. Conheça nossos mestres barbeiros e sinta a diferença.</p>
                <a href="agendamento.html" class="btn">Agende seu horário <i class="fas fa-calendar-alt"></i></a>
            </div>
        </section>

        <section id="servicos" class="servicos-destaque">
            <h2>Nossos serviços</h2>
            <div class="cards">
                <div class="card"><i class="fas fa-cut fa-3x"></i><h3>Corte Degradê</h3><p>Moderno e estiloso.</p></div>
                <div class="card"><i class="fas fa-beard fa-3x"></i><h3>Barba Completa</h3><p>Modelagem e hidratação.</p></div>
                <div class="card"><i class="fas fa-child fa-3x"></i><h3>Corte Infantil</h3><p>Atendimento especial.</p></div>
                <div class="card"><i class="fas fa-tint fa-3x"></i><h3>Hidratação Capilar</h3><p>Revitalização profunda.</p></div>
                <div class="card"><i class="fas fa-mask fa-3x"></i><h3>Pigmentação</h3><p>Cobrir fios brancos.</p></div>
                <div class="card"><i class="fas fa-hand-sparkles fa-3x"></i><h3>Sobrancelha</h3><p>Design com precisão.</p></div>
            </div>
        </section>

        <section class="barbeiros">
            <h2>Nossos Barbeiros</h2>
            <div class="barbeiros-grid">
                <div class="barbeiro-card"><img src="images/barbeiro1.jpg" alt="Roger"><h3>Roger</h3><p>Especialista em cortes degradê.</p></div>
                <div class="barbeiro-card"><img src="images/barbeiro2.jpg" alt="Carlos"><h3>Carlos</h3><p>Mestre em cortes clássicos.</p></div>
            </div>
        </section>

        <section class="instagram">
            <h2>Siga-nos no Instagram</h2>
            <p>@barbearia.aldeia</p>
            <a href="https://instagram.com/barbearia.aldeia" target="_blank" class="instagram-follow-button"><i class="fab fa-instagram"></i> Siga-nos</a>
        </section>
    </main>

    <footer id="contato">
        <p>&copy; 2025 Barbearia Aldeia - Todos os direitos reservados.</p>
        <div class="social">
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-facebook"></i></a>
            <a href="#"><i class="fab fa-whatsapp"></i></a>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
